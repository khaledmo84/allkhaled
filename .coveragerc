[run]
source = alkhaled
omit =
    */tests/*
    */venv/*
    */__pycache__/*
    */site-packages/*
    */migrations/*
    */scripts/*
    run.py
    setup.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    @abstractmethod
    if TYPE_CHECKING:
fail_under = 70
show_missing = True
