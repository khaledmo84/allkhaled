# -----------------------------------------------------------------------------
# 5. مفاتيح APIs للذكاء الاصطناعي اللامركزي (Decentralized AI APIs)
# -----------------------------------------------------------------------------
AI_HORDE_API_KEY=your_ai_horde_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_token_here
GOLEM_API_KEY=your_golem_api_key_here
IEXEC_API_KEY=your_iexec_api_key_here
THREEFOLD_API_KEY=your_threefold_api_key_here
BACALHAU_API_KEY=your_bacalhau_api_key_here
NOSANA_API_KEY=your_nosana_api_key_here
PETALS_API_KEY=your_petals_api_key_here

# -----------------------------------------------------------------------------
# 6. مفاتيح المحفظة والأمان (Wallet & Security Keys) – شديدة الحساسية
# -----------------------------------------------------------------------------
# المفتاح الخاص للمحفظة الرئيسية (يبدأ بـ 0x)
DEPLOYER_PRIVATE_KEY=0xyour_private_key_hex_here

# المحفظة الثانوية (لتحويل الأموال)
SECONDARY_WALLET=0x0000000000000000000000000000000000000000

# المفتاح الرئيسي للتشفير (32 بايت بصيغة Hex)
ALKHALED_MASTER_KEY=your_32_byte_hex_master_key_here

# مفاتيح AWS (لـ HSM)
AWS_HSM_PIN=your_aws_hsm_pin
AWS_HSM_SLOT=0

# مفاتيح HashiCorp Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your_vault_token
VAULT_ROLE_ID=your_vault_role_id
VAULT_SECRET_ID=your_vault_secret_id
VAULT_NAMESPACE=admin

# -----------------------------------------------------------------------------
# 7. قواعد البيانات والتخزين المؤقت (Databases & Cache)
# -----------------------------------------------------------------------------
# Redis (للتخزين المؤقت الموزع و Idempotency)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your_redis_password
REDIS_SSL=false

# Upstash Redis (بديل مجاني وسحابي)
UPSTASH_REDIS_URL=https://your-upstash-redis-url
UPSTASH_REDIS_TOKEN=your_upstash_redis_token

# PostgreSQL (لـ ExperienceDB المتقدم)
POSTGRES_URL=postgresql://user:password@localhost:5432/alkhaled
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=40

# TimescaleDB (للبيانات الزمنية)
TIMESCALEDB_URL=postgresql://user:password@localhost:5433/alkhaled_ts

# Neon (PostgreSQL serverless مجاني)
NEON_CONNECTION_STRING=postgresql://user:password@host/db

# Turso (SQLite اللامركزية)
TURSO_DB_URL=https://your-turso-db-url
TURSO_AUTH_TOKEN=your_turso_auth_token

# MongoDB Atlas (قاعدة بيانات موزعة)
MONGODB_CONNECTION_STRING=mongodb://username:password@localhost:27017
MONGODB_DATABASE=alkhaled

# PlanetScale (MySQL serverless)
PLANETSCALE_DSN=mysql://user:password@host/db

# Supabase (PostgreSQL + Realtime)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Appwrite
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# SQLite (للتخزين المحلي)
SQLITE_DB_PATH=alkhaled.db
SQLITE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# 8. خدمات السحابة والتخزين (Cloud & Storage)
# -----------------------------------------------------------------------------
# Cloudflare (Workers, R2, D1, Queues)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# Cloudflare R2 (تخزين كائنات)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=your_r2_bucket_name
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Cloudflare D1 (قاعدة بيانات موزعة)
D1_DATABASE_ID=your_d1_database_id
D1_DATABASE_NAME=alkhaled-d1

# Cloudflare Queues (معالجة غير متزامنة)
QUEUE_NAME=alkhaled-queue

# AWS (S3, Lambda, ECS)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_LAMBDA_ROLE_ARN=arn:aws:iam::account:role/lambda-role
AWS_S3_BUCKET=your-s3-bucket
AWS_ECS_CLUSTER=alkhaled-cluster

# Google Cloud (Firestore, Cloud Functions, Cloud Run)
GCP_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GCP_REGION=us-central1
GCP_CLOUD_RUN_URL=https://alkhaled-xxx-uc.a.run.app

# DigitalOcean Spaces
SPACES_BUCKET=your_spaces_bucket
SPACES_ACCESS_KEY=your_spaces_access_key
SPACES_SECRET_KEY=your_spaces_secret_key
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Azure (Blob Storage, Container Instances)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_CONTAINER_NAME=alkhaled
AZURE_RESOURCE_GROUP=alkhaled-rg

# IPFS (للتخزين اللامركزي)
IPFS_API_URL=/ip4/127.0.0.1/tcp/5001
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
IPFS_PINNING_SERVICE=pinata
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret

# Arweave (تخزين دائم)
ARWEAVE_WALLET_PATH=/path/to/arweave-wallet.json

# Filecoin (تخزين لامركزي مع حوافز)
FILECOIN_API_KEY=your_filecoin_api_key

# Ceramic Network (تخزين لامركزي قابل للتحديث)
CERAMIC_URL=https://ceramic-clay.3boxlabs.com

# Tableland (SQL على السلسلة)
TABLELAND_CHAIN=ethereum
TABLELAND_PRIVATE_KEY=your_tableland_private_key

# -----------------------------------------------------------------------------
# 9. منصات النشر والتوزيع (Deployment Platforms)
# -----------------------------------------------------------------------------
# Vercel
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_vercel_team_id

# Netlify
NETLIFY_TOKEN=your_netlify_token
NETLIFY_SITE_ID=your_netlify_site_id

# Railway
RAILWAY_TOKEN=your_railway_token

# Render
RENDER_API_KEY=your_render_api_key
RENDER_SERVICE_ID=your_render_service_id

# Koyeb
KOYEB_API_KEY=your_koyeb_api_key
KOYEB_APP_NAME=alkhaled

# Zeabur
ZEABUR_API_KEY=your_zeabur_api_key
ZEABUR_PROJECT_ID=your_zeabur_project_id

# Fly.io
FLY_ACCESS_TOKEN=your_fly_access_token
FLY_APP_NAME=alkhaled

# Google Cloud Run
GCP_CLOUD_RUN_SERVICE=alkhaled

# AWS ECS
AWS_ECS_TASK_DEFINITION=alkhaled-task

# Kubernetes (للاستضافة الذاتية)
K8S_NAMESPACE=alkhaled
K8S_CONFIG_PATH=/path/to/kubeconfig

# Portainer (لإدارة الحاويات)
PORTAINER_URL=http://localhost:9000
PORTAINER_API_KEY=your_portainer_api_key

# NixOS (لإدارة النظام)
NIXOS_HOST=your-nixos-host
NIXOS_SSH_KEY_PATH=/path/to/ssh-key

# -----------------------------------------------------------------------------
# 10. أدوات المراقبة والتتبع (Monitoring & Observability)
# -----------------------------------------------------------------------------
# Sentry (تتبع الأخطاء)
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# SigNoz (بديل مفتوح المصدر لـ DataDog)
SIGNOZ_ENDPOINT=http://localhost:4317
SIGNOZ_METRICS_ENDPOINT=http://localhost:4318

# Grafana Loki (تجميع السجلات)
LOKI_URL=http://localhost:3100
LOKI_TENANT_ID=alkhaled

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_PUSH_GATEWAY=http://localhost:9091

# OpenTelemetry
OTEL_SERVICE_NAME=alkhaled
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Honeycomb (اختياري – مدفوع)
HONEYCOMB_API_KEY=your_honeycomb_api_key
HONEYCOMB_DATASET=alkhaled

# Datadog (مدفوع)
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DATADOG_SITE=datadoghq.com

# New Relic (مدفوع)
NEW_RELIC_LICENSE_KEY=your_new_relic_key
NEW_RELIC_APP_NAME=alkhaled

# -----------------------------------------------------------------------------
# 11. التنبيهات والإشعارات (Alerts & Notifications)
# -----------------------------------------------------------------------------
# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your_webhook
SLACK_BOT_TOKEN=your_slack_bot_token

# PagerDuty (للتنبيهات الحرجة)
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_key
PAGERDUTY_SERVICE_ID=your_pagerduty_service_id

# Email (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=admin@example.com
ALERT_EMAIL_FROM=alerts@alkhaled.com

# Matrix Protocol (مراسلة لامركزية)
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USERNAME=your_matrix_username
MATRIX_PASSWORD=your_matrix_password
MATRIX_ROOM_ID=!room_id:matrix.org

# -----------------------------------------------------------------------------
# 12. إعدادات البيئة والتشغيل (Runtime & Environment)
# -----------------------------------------------------------------------------
# وضع التشغيل: development / staging / production
ENVIRONMENT=production

# مستوى التسجيل: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# منفذ الخادم الرئيسي (لـ FastAPI أو HealthCheck)
PORT=8080

# منفذ HealthCheck Server
HEALTH_PORT=8081

# منفذ Prometheus Metrics
METRICS_PORT=9090

# عنوان IP للربط
HOST=0.0.0.0

# عدد العمال (لـ Uvicorn)
WORKERS=4

# -----------------------------------------------------------------------------
# 13. إعدادات متقدمة للبوت (Advanced Bot Settings)
# -----------------------------------------------------------------------------
# الحد الأدنى للربح بالدولار (لتنفيذ الصفقة)
MIN_PROFIT=10.0

# الحد الأدنى للثقة (0-1)
MIN_CONFIDENCE=0.3

# الحد الأقصى لعدد الفرص المتزامنة
MAX_OPPS=100

# الحد الأقصى للـ gas بالوحدات
MAX_GAS_UNITS=300000

# الحد الأقصى للانزلاق (slippage)
MAX_SLIPPAGE=0.01

# الحد الأقصى للخسارة اليومية بالدولار
MAX_DAILY_LOSS=1000.0

# الحد الأقصى لحجم المركز بالدولار
MAX_POSITION_SIZE=10000.0

# -----------------------------------------------------------------------------
# 14. إعدادات الـ P2P والشبكات اللامركزية (P2P & Decentralized Networks)
# -----------------------------------------------------------------------------
# عنوان الاستماع لـ libp2p
P2P_LISTEN_ADDRESS=/ip4/0.0.0.0/tcp/0

# قائمة العقد البادئة (bootstrap peers)
P2P_BOOTSTRAP_PEERS=/ip4/104.131.131.82/tcp/4001/p2p/QmaCpDMGvV2BGHeYERUEnRQAwe3N8SzbUtfsmvsqQLuvuJ

# معرف العقدة المحلية (اختياري)
P2P_NODE_ID=alkhaled-node-1

# -----------------------------------------------------------------------------
# 15. إعدادات الـ HTTP Client (SmartHTTPClient)
# -----------------------------------------------------------------------------
HTTP_MAX_RETRIES=3
HTTP_BASE_DELAY=1.0
HTTP_MAX_DELAY=30.0
HTTP_CIRCUIT_BREAKER_THRESHOLD=5
HTTP_CIRCUIT_BREAKER_TIMEOUT=60.0

# -----------------------------------------------------------------------------
# 16. إعدادات Idempotency Keys
# -----------------------------------------------------------------------------
IDEMPOTENCY_TTL=3600
IDEMPOTENCY_CLEANUP_INTERVAL=300
IDEMPOTENCY_USE_UPSTASH=true

# -----------------------------------------------------------------------------
# 17. إعدادات MemoryGuard (مراقبة الذاكرة)
# -----------------------------------------------------------------------------
MEMORY_MAX_MB=500
MEMORY_CHECK_INTERVAL=60

# -----------------------------------------------------------------------------
# 18. إعدادات GracefulShutdown (الإيقاف الآمن)
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT=30.0

# -----------------------------------------------------------------------------
# 19. إعدادات الـ Rollback (التراجع متعدد الإصدارات)
# -----------------------------------------------------------------------------
ROLLBACK_MAX_VERSIONS=5
ROLLBACK_STORAGE_DIR=.rollback_snapshots

# -----------------------------------------------------------------------------
# 20. إعدادات الـ CrashReporter (مبلغ الأعطال)
# -----------------------------------------------------------------------------
CRASH_REPORTER_DIR=.crash_reports
CRASH_REPORTER_MAX_REPORTS=20

# -----------------------------------------------------------------------------
# 21. إعدادات Litestream (التكرار الحي لقاعدة البيانات)
# -----------------------------------------------------------------------------
LITESTREAM_S3_BUCKET=your-litestream-bucket
LITESTREAM_REPLICA_INTERVAL=1m

# -----------------------------------------------------------------------------
# 22. إعدادات Chaos Engineering (حقن الأخطاء المتعمدة – للاختبار فقط)
# -----------------------------------------------------------------------------
CHAOS_MODE=false
CHAOS_INJECTION_PROBABILITY=0.001

# -----------------------------------------------------------------------------
# 23. إعدادات Celery (المهام الموزعة)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# -----------------------------------------------------------------------------
# 24. إعدادات Docker (للحاويات)
# -----------------------------------------------------------------------------
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_REGISTRY=ghcr.io/alkhaled

# -----------------------------------------------------------------------------
# 25. إعدادات إضافية للمنصات (Additional Platform Settings)
# -----------------------------------------------------------------------------
# Rapid.Space (منصة سحابية مفتوحة المصدر)
RAPIDSPACE_API_KEY=your_rapidspace_api_key

# Hostim.dev
HOSTIM_TOKEN=your_hostim_token

# Glitch
GLITCH_TOKEN=your_glitch_token

# InfinityFree (FTP)
INFINITYFREE_FTP_HOST=ftp.infinityfree.net
INFINITYFREE_FTP_USER=your_ftp_user
INFINITYFREE_FTP_PASSWORD=your_ftp_password

# ClawCloud
CLAWCLOUD_API_KEY=your_clawcloud_api_key

# -----------------------------------------------------------------------------
# 26. متغيرات مخصصة للعقل المدبر (ThinkingCore)
# -----------------------------------------------------------------------------
THINKING_CORE_ENABLED=true
THINKING_CORE_ANALYSIS_INTERVAL=3600

# -----------------------------------------------------------------------------
# 27. متغيرات مخصصة لـ ErrorShield
# -----------------------------------------------------------------------------
ERROR_SHIELD_ENABLED=true
ERROR_SHIELD_HEALING_INTERVAL=10.0

